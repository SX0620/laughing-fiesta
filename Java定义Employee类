package Class;

public class Employee {
    private int id;
    private String name;
    private String position;
    private double salary;

    public Employee(){
    }

    public Employee(int id,String name,String position,double salary){
        this.id=id;
        this.name=name;
        this.position=position;
        this.salary=salary;
    }

    public int getId(){
        return id;
    }

    public void setId(int id){
        this.id=id;
    }
    public String getName(){
        return name;
    }

    public void setName(String name){
        this.name=name;
    }

    public String getPosition(){
        return position;
    }

    public void setPosition(String position){
        this.position=position;
    }

    public double getSalary(){
        return salary;
    }

    public void setSalary(double salary){
        this.salary=salary;
    }

    public void greet(){
        System.out.println("你好，我是员工"+name+"!");
    }

    public void showInfo(){
        System.out.println("=====雇员信息=====");
        System.out.println("雇员编号："+id);
        System.out.println("姓名"+name);
        System.out.println("岗位"+position);
        System.out.println("基本工资"+salary+"元");
        System.out.println("================");
    }

    public void raiseSalary(double percent){
        double raiseAmount=salary*percent/100;
        double newSalary=salary+raiseAmount;
        this.salary=newSalary;
        System.out.println(name+"涨薪完成！涨薪比例："+percent+"%,涨薪金额："+raiseAmount+"元，涨薪后工资："+newSalary+"元");
    }

}


public class TestEmployee {
    public static void main(String[] args) {
        Employee employee=new Employee(1001,"张亮","Java开发工程师",800);
        employee.showInfo();
        employee.greet();
        employee.setPosition("Java项目经理");
        employee.raiseSalary(10);
        employee.showInfo();
    }
}
