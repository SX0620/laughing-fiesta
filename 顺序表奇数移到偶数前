#include <stdio.h>
#define MAXSIZE 100

typedef struct {
    int data[MAXSIZE];
    int length;
} SeqList;

void Move(SeqList *L) {
    int i = 0, j = L->length - 1;
    int temp;
    while (i < j) {
        // 从左找偶数
        while (i < j && L->data[i] % 2 != 0) {
            i++;
        }
        // 从右找奇数
        while (i < j && L->data[j] % 2 == 0) {
            j--;
        }
        // 交换
        if (i < j) {
            temp = L->data[i];
            L->data[i] = L->data[j];
            L->data[j] = temp;
        }
    }
}

// 测试
int main() {
    SeqList L = {{1, 2, 3, 4, 5, 6, 7, 8, 9}, 9};
    Move(&L);
    int i;
    for ( i = 0; i < L.length; i++) {
        printf("%d ", L.data[i]);
    }
    return 0;
}
